{
  "item": {
    "name": "Create Document (Version 1)",
    "request": {
      "method": "POST",
      "header": [
        {
          "key": "Accept",
          "value": "application/json"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mode": "raw",
        "raw": "{\n  \"knowledge_base_category_id\": \"01HYYYY...\",\n  \"title\": \"How to process a refund\",\n  \"content\": \"# Refund Process\\n1. Check eligibility\\n2. Process via Stripe.\",\n  \"content_format\": \"markdown\"\n}"
      },
      "url": {
        "raw": "{{base_url}}/api/ai/knowledge-bases/:knowledge_base_id/documents",
        "host": [
          "{{base_url}}"
        ],
        "path": [
          "api",
          "ai",
          "knowledge-bases",
          ":knowledge_base_id",
          "documents"
        ],
        "variable": [
          {
            "key": "knowledge_base_id",
            "value": "01HXXXX..."
          }
        ]
      },
      "description": "Create a new document. The system will automatically create Version 1 from the content provided."
    }
  },
  "order": 20
}