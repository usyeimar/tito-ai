{
  "item": {
    "name": "Update Document (New Version)",
    "request": {
      "method": "PATCH",
      "header": [
        {
          "key": "Accept",
          "value": "application/json"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mode": "raw",
        "raw": "{\n  \"status\": \"published\",\n  \"content\": \"# Refund Process V2\\nUpdated instructions...\"\n}"
      },
      "url": {
        "raw": "{{base_url}}/api/ai/knowledge-bases/:knowledge_base_id/documents/:document_id",
        "host": [
          "{{base_url}}"
        ],
        "path": [
          "api",
          "ai",
          "knowledge-bases",
          ":knowledge_base_id",
          "documents",
          ":document_id"
        ],
        "variable": [
          {
            "key": "knowledge_base_id",
            "value": "01HXXXX..."
          },
          {
            "key": "document_id",
            "value": "01HZZZZ..."
          }
        ]
      },
      "description": "Update a document. Passing `content` automatically creates a new version history."
    }
  },
  "order": 40
}