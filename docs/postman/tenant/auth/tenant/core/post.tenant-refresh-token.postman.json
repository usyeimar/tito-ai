{
  "item": {
    "name": "Tenant Refresh Token",
    "request": {
      "method": "POST",
      "header": [
        {
          "key": "Accept",
          "value": "application/json"
        },
        {
          "key": "X-Auth-Mode",
          "value": "{{auth_mode}}"
        }
      ],
      "body": {
        "mode": "raw",
        "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
        "options": {
          "raw": {
            "language": "json"
          }
        }
      },
      "url": {
        "raw": "{{base_url}}/{{tenant_slug}}/api/refresh",
        "host": [
          "{{base_url}}"
        ],
        "path": [
          "{{tenant_slug}}",
          "api",
          "refresh"
        ]
      },
      "description": "Uses X-Auth-Mode (token|cookie). Cookie mode reads refresh token from cookies, sets HttpOnly cookies, and omits tokens from JSON."
    },
    "response": [
      {
        "name": "200 Refreshed",
        "originalRequest": {
          "method": "POST",
          "header": [],
          "url": {
            "raw": "{{base_url}}/{{tenant_slug}}/api/refresh",
            "host": [
              "{{base_url}}"
            ],
            "path": [
              "{{tenant_slug}}",
              "api",
              "refresh"
            ]
          }
        },
        "status": "OK",
        "code": 200,
        "_postman_previewlanguage": "Text",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "cookie": [],
        "body": "{\n  \"data\": {\n    \"access_token\": \"token\",\n    \"refresh_token\": \"refresh_token\",\n    \"expires_in\": 3600,\n    \"token_type\": \"Bearer\"\n  }\n}"
      }
    ],
    "event": [
      {
        "listen": "test",
        "script": {
          "type": "text/javascript",
          "exec": [
            "const payload = pm.response.json();",
            "if (payload && payload.data) {",
            "  const data = payload.data;",
            "  if (data.access_token) {",
            "    pm.collectionVariables.set('tenant_access_token', data.access_token);",
            "    pm.collectionVariables.set('token', data.access_token);",
            "  }",
            "  if (data.refresh_token) {",
            "    pm.collectionVariables.set('tenant_refresh_token', data.refresh_token);",
            "    pm.collectionVariables.set('refresh_token', data.refresh_token);",
            "  }",
            "}"
          ]
        }
      }
    ]
  },
  "order": 10
}