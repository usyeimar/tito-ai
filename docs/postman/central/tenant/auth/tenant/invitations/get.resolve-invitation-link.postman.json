  "item": {
    "name": "Resolve Invitation Link",
    "request": {
      "method": "GET",
      "header": [
        {
          "key": "Accept",
          "value": "application/json"
        }
      ],
      "url": {
        "raw": "{{base_url}}/api/auth/invitations/resolve?expires={{invitation_expires}}&token={{invitation_token}}&signature={{invitation_signature}}",
        "host": [
          "{{base_url}}"
        ],
        "path": [
          "api",
          "auth",
          "invitations",
          "resolve"
        ],
        "query": [
          {
            "key": "expires",
            "value": "{{invitation_expires}}"
          },
          {
            "key": "token",
            "value": "{{invitation_token}}"
          },
          {
            "key": "signature",
            "value": "{{invitation_signature}}"
          }
        ]
      },
      "description": "Resolve an invitation URL and fetch invitation details.\n\n**Auth:** not required.\n\n**Query params:**\n- `expires` (required for signed middleware)\n- `token` (required|string)\n- `signature` (required for signed middleware)\n\n**Important:** keep query param order as `expires`, `token`, `signature`; signature depends on original URL order.\n\n**Behavior:**\n- Signed middleware validates URL signature and expiry\n- `token` is hashed server-side and matched against stored invitation token hash\n- Stale or superseded links return `410 INVITATION_LINK_INVALID`\n- Returns invitation resource including linked tenant"
    },
