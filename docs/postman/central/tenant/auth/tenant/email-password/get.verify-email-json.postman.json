  "item": {
    "name": "Verify Email (JSON)",
    "request": {
      "method": "GET",
      "header": [
        {
          "key": "Accept",
          "value": "application/json"
        }
      ],
      "url": {
        "raw": "{{base_url}}/api/auth/email/verify/{{verification_id}}/{{verification_hash}}?signature={{verification_signature}}&expires={{verification_expires}}",
        "host": [
          "{{base_url}}"
        ],
        "path": [
          "api",
          "auth",
          "email",
          "verify",
          "{{verification_id}}",
          "{{verification_hash}}"
