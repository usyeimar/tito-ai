  "item": {
    "name": "Create Impersonation URL",
    "request": {
      "method": "POST",
      "header": [
        {
          "key": "Accept",
          "value": "application/json"
        }
      ],
      "body": {
        "mode": "raw",
        "raw": "{\n  \"tenant\": \"{{tenant_slug}}\",\n  \"redirect_url\": \"/dashboard\"\n}",
        "options": {
          "raw": {
            "language": "json"
          }
        }
      },
