{
  "item": {
    "name": "Update Password",
    "request": {
      "method": "PATCH",
      "header": [
        {
          "key": "Accept",
          "value": "application/json"
        }
      ],
      "body": {
        "mode": "raw",
        "raw": "{\n  \"current_password\": \"{{password}}\",\n  \"password\": \"{{new_password}}\",\n  \"password_confirmation\": \"{{new_password}}\",\n  \"close_all_sessions\": false\n}",
        "options": {
          "raw": {
            "language": "json"
          }
        }
      },
      "url": {
        "raw": "{{base_url}}/api/auth/me/password",
        "host": [
          "{{base_url}}"
        ],
        "path": [
          "api",
          "auth",
          "me",
          "password"
        ]
      },
      "description": "Requires the current password. If close_all_sessions is true, all sessions will be closed. Otherwise, all other sessions except the current one will be closed."
    }
  },
  "order": 40
}