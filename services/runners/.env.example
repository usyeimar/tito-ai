PROJECT_NAME="Tito AI Runners"

# === TRANSPORTE WebRTC ===
# Daily.co
DAILY_API_KEY=tu_daily_api_key
DAILY_API_URL=https://api.daily.co/v1

# LiveKit
LIVEKIT_URL=wss://tu-proyecto.livekit.cloud
LIVEKIT_API_KEY=tu_livekit_api_key
LIVEKIT_API_SECRET=tu_livekit_api_secret

# === LLM ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === STT ===
DEEPGRAM_API_KEY=tu_deepgram_api_key

# === TTS ===
CARTESIA_API_KEY=sk_car_xxxxxxxxxxxxxxxx
ELEVENLABS_API_KEY=tu_elevenlabs_api_key

# === REDIS ===
REDIS_URL=redis://localhost:6379/0

# === BACKEND (webhooks a Laravel) ===
BACKEND_URL=http://localhost:8000
BACKEND_API_KEY=tu_backend_api_key

# === SCALING ===
MAX_CONCURRENT_SESSIONS=10
DEFAULT_TRANSPORT_PROVIDER=daily

# === SIP BRIDGE (opcional) ===
SIP_ENABLED=false
# Transport mode: "audiosocket" (default), "websocket", or "ari"
SIP_TRANSPORT=audiosocket
# Asterisk AMI
ASTERISK_AMI_HOST=localhost
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=tito
ASTERISK_AMI_SECRET=changeme
# AudioSocket TCP server (donde Asterisk se conecta)
SIP_AUDIOSOCKET_HOST=0.0.0.0
SIP_AUDIOSOCKET_PORT=9092
# ARI (Asterisk REST Interface) — only needed when SIP_TRANSPORT=ari
ASTERISK_ARI_HOST=asterisk
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=tito-ai
ASTERISK_ARI_PASSWORD=tito-ari-secret
ASTERISK_ARI_APP=tito-ai
